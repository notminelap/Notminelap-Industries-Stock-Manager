# Copy this file to .env and fill in your values for local development
# NEVER commit .env to git

# MongoDB connection string
# Get this from MongoDB Atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/notminelap-industries?retryWrites=true&w=majority

# Port (optional, defaults to 3002)
PORT=3002

# JWT secret for authentication tokens
JWT_SECRET=your-secret-key-change-this

# Initial admin credentials (used by seed.js)
ADMIN_USERNAME=notminelap
ADMIN_PASSWORD=your-admin-password
